{
  "name": "ai2web-demo-store",
  "main": "src/index.ts",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "durable_objects": {
    "bindings": [{ "name": "STORE_MCP", "class_name": "StoreMCP" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["StoreMCP"] }]
}
